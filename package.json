{
  "name": "icare-validate",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Client-side, offline-capable validation of iCARE absolute-risk models.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "vendor": "wasm-icare-vendor public/pyodide",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@observablehq/plot": "^0.6.17",
    "katex": "^0.17.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "wasm-icare": "^2.0.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/katex": "^0.16.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^8.0.0",
    "vite-plugin-pwa": "^1.3.0"
  }
}
